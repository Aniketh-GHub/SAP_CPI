            <bpmn2:timerEventDefinition id="TimerEventDefinition_96136">
                <bpmn2:extensionElements>
                    <ifl:property>
                        <key>scheduleKey</key>
                        <value>&lt;row>&lt;cell>dateType&lt;/cell>&lt;cell>SIMPLE&lt;/cell>&lt;/row>&lt;row>&lt;cell>hourValue&lt;/cell>&lt;cell>17&lt;/cell>&lt;/row>&lt;row>&lt;cell>minutesValue&lt;/cell>&lt;cell>21&lt;/cell>&lt;/row>&lt;row>&lt;cell>timeType&lt;/cell>&lt;cell>ON_TIME&lt;/cell>&lt;/row>&lt;row>&lt;cell>timeZone&lt;/cell>&lt;cell>( UTC 0:00 ) Greenwich Mean Time(Etc/GMT)&lt;/cell>&lt;/row>&lt;row>&lt;cell>throwExceptionOnExpiry&lt;/cell>&lt;cell>true&lt;/cell>&lt;/row>&lt;row>&lt;cell>second&lt;/cell>&lt;cell>0&lt;/cell>&lt;/row>&lt;row>&lt;cell>minute&lt;/cell>&lt;cell>0/5&lt;/cell>&lt;/row>&lt;row>&lt;cell>hour&lt;/cell>&lt;cell>*&lt;/cell>&lt;/row>&lt;row>&lt;cell>day_of_month&lt;/cell>&lt;cell>?&lt;/cell>&lt;/row>&lt;row>&lt;cell>month&lt;/cell>&lt;cell>*&lt;/cell>&lt;/row>&lt;row>&lt;cell>dayOfWeek&lt;/cell>&lt;cell>*&lt;/cell>&lt;/row>&lt;row>&lt;cell>year&lt;/cell>&lt;cell>*&lt;/cell>&lt;/row>&lt;row>&lt;cell>startAt&lt;/cell>&lt;cell>&lt;/cell>&lt;/row>&lt;row>&lt;cell>endAt&lt;/cell>&lt;cell>&lt;/cell>&lt;/row>&lt;row>&lt;cell>attributeBehaviour&lt;/cell>&lt;cell>isThrowExceptionOnExpiryVisible,isScheduleAdvancedVisible,isScheduleAdvancedStartEndVisible,isScheduleSimpleVisible&lt;/cell>&lt;/row>&lt;row>&lt;cell>triggerType&lt;/cell>&lt;cell>cron&lt;/cell>&lt;/row>&lt;row>&lt;cell>noOfSchedules&lt;/cell>&lt;cell>1&lt;/cell>&lt;/row&gt;&lt;row>&lt;cell>schedule1&lt;/cell>&lt;cell>simple.repeat=NONE&amp;amp;trigger.timeZone=Etc/GMT&lt;/cell>&lt;/row></value>
                    </ifl:property>
